# Ollama 提供商配置示例
# 复制此文件为 .env 并填入实际值

# Ollama 服务地址（本地部署）
OLLAMA_URL=http://localhost:11434

# Ollama 服务地址（线上服务，需要 API Key）
# OLLAMA_URL=https://api.ollama.com

# Ollama API Key（仅线上服务需要）
# 从 Ollama 控制台获取：https://ollama.com/settings/api
OLLAMA_API_KEY=your_api_key_here

# 默认模型名称
OLLAMA_MODEL=qwen3-coder-next:q8_0

# 算力容量 (token/s)
OLLAMA_CAPACITY=50

# Token 分割阈值
OLLAMA_TOKEN_THRESHOLD=4096
