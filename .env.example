# Ollama 提供商配置示例
# 复制此文件为 .env 并填入实际值

# Ollama 服务地址（本地部署）
OLLAMA_URL=http://localhost:11434

# Ollama 服务地址（线上服务，需要 API Key）
# OLLAMA_URL=https://api.ollama.com

# Ollama API Key（仅线上服务需要）
# 从 Ollama 控制台获取：https://ollama.com/settings/api
OLLAMA_API_KEY=your_api_key_here

# 默认模型名称
OLLAMA_MODEL=qwen3-coder-next:q8_0

# 算力容量 (token/s)
OLLAMA_CAPACITY=50

# Token 分割阈值
OLLAMA_TOKEN_THRESHOLD=4096

# =============================================================================
# 阿里云百炼 Qwen API 配置
# =============================================================================

# 阿里云百炼 API Key
# 从阿里云百炼控制台获取：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your_api_key_here

# 阿里云区域选择
# 可选值：cn-beijing, singapore, us-virginia
# - cn-beijing: 中国北京（默认）
# - singapore: 新加坡
# - us-virginia: 美国弗吉尼亚
ALIYUN_REGION=cn-beijing

# 自定义端点（可选，如果设置则覆盖区域默认端点）
# ALIYUN_CUSTOM_ENDPOINT=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1

# 默认模型名称
# 可选模型：
# - qwen3-max, qwen3.5-plus, qwen3.5-flash
# - qwen-plus, qwen-flash
# - qwen3-coder-plus, qwen3-coder-flash
ALIYUN_MODEL=qwen3.5-plus

# 算力容量 (token/s)
ALIYUN_CAPACITY=100

# 请求超时 (毫秒)
ALIYUN_TIMEOUT_MS=30000

# 最大重试次数
ALIYUN_MAX_RETRIES=3

# 是否启用思考模式（仅部分模型支持）
ALIYUN_ENABLE_THINKING=false

# 是否启用工具调用
ALIYUN_ENABLE_TOOLS=false

# 内置工具列表（逗号分隔）
# 可选工具：web_search, web_extractor, code_interpreter, file_search
ALIYUN_BUILT_IN_TOOLS=
